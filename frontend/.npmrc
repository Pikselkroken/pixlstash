# Make `npm ci` resilient to transient registry/network failures (ECONNRESET,
# "network aborted") that intermittently kill CI runs. npm's defaults — 2 retries
# over a 10s..60s window — exhaust too quickly on flaky runners, so widen it.
# Applies to every npm invocation run from frontend/: the setup.py wheel build and
# the dedicated CI steps (ci.yml, electron.yml, windows-installer.yml) alike.
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
