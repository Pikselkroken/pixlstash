{
  "name": "pixlstash-frontend",
  "private": true,
  "version": "1.6.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-version": "node ../scripts/sync-node-versions.mjs frontend",
    "build": "npm run sync-version && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "playwright test --config=playwright.screenshots.config.js",
    "screenshots:script": "node ../website/screenshots/extract-script.mjs"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.16.0",
    "compromise": "^14.14.4",
    "lodash-es": "^4.18.1",
    "marked": "^16.4.1",
    "pinia": "^3.0.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.22",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0"
  }
}
